# 1. ใช้ Node.js เวอร์ชัน 20 เป็นพื้นฐาน
FROM node:20-alpine

# 2. สร้างโฟลเดอร์ /app ภายในกล่องสำหรับทำงาน
WORKDIR /app

# 3. ก๊อปปี้ไฟล์บัญชีรายชื่อเครื่องมือ (package.json) เข้าไปก่อน
COPY package*.json ./

# 4. สั่งติดตั้งเครื่องมือตามบัญชีรายชื่อ
RUN npm install

# 5. ก๊อปปี้โค้ดที่เหลือทั้งหมดของเรา (เช่น index.js) ตามเข้าไป
COPY . .

# 6. บอกกล่องว่าให้เปิดช่องทางสื่อสารที่พอร์ต 3000
EXPOSE 3000

# 7. คำสั่งที่จะรันทันทีเมื่อเปิดกล่อง
CMD ["node", "index.js"]